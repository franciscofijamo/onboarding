// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String?  @unique
  name      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  creditBalance      CreditBalance?
  usageHistory       UsageHistory[]
  storageObjects     StorageObject[]
  subscriptionEvents SubscriptionEvent[]
  essays             Essay[]
  flashcardDecks     FlashcardDeck[]
  audioInterviewSessions AudioInterviewSession[]
  asaasCustomerId    String?   @unique
  asaasCustomerIdSandbox    String?   @unique
  asaasCustomerIdProduction String?   @unique
  asaasSubscriptionId String?
  currentPlanId      String?
  cpfCnpj            String?
  billingPeriodEnd      DateTime?
  cancellationScheduled Boolean  @default(false)
  cancellationDate      DateTime?
  
  // Profile completion fields
  province         String?
  birthYear        Int?
  gender           String?
  course           String?
  university       String?
  profileComplete  Boolean  @default(false)

  @@index([email])
  @@index([name])
  @@index([createdAt])
  @@index([isActive])
  @@index([currentPlanId])
}


// Workspace features and linkage to projects
model Feature {
  id          String     @id @default(cuid())
  workspaceId String
  name        String
  description String?
  tags        String[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
}

model CreditBalance {
  id                String   @id @default(cuid())
  userId            String   @unique
  clerkUserId       String   @unique
  creditsRemaining  Int      @default(100)  // Cached from Clerk
  lastSyncedAt      DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id])
  usageHistory      UsageHistory[]

  @@index([userId])
  @@index([clerkUserId])
  @@index([creditsRemaining])
  @@index([lastSyncedAt])
}

// Track individual usage events
model UsageHistory {
  id              String   @id @default(cuid())
  userId          String
  creditBalanceId String
  operationType   OperationType
  creditsUsed     Int
  details         Json?
  timestamp       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id])
  creditBalance   CreditBalance @relation(fields: [creditBalanceId], references: [id])

  @@index([userId])
  @@index([creditBalanceId])
  @@index([timestamp])
  @@index([operationType])
  @@index([userId, timestamp])
  @@index([operationType, timestamp])
}

enum OperationType {
  AI_TEXT_CHAT
  AI_IMAGE_GENERATION
  ESSAY_ANALYSIS
  MOCK_INTERVIEW_DECK
  AUDIO_INTERVIEW
}

enum EssayType {
  LEADERSHIP
  NETWORKING
  COURSE_CHOICES
  CAREER_PLAN
  GRANT_PURPOSE
  PERSONAL_STATEMENT
}

enum FulbrightCategory {
  STUDENT
  YOUNG_PROFESSIONAL
  RESEARCHER
}

enum EssayStatus {
  DRAFT
  ANALYZING
  ANALYZED
  FINALIZED
}

// Singleton row storing admin-configurable credit settings
model AdminSettings {
  id           String   @id @default("singleton")
  featureCosts Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Subscription plans managed manually and optionally linked to payment providers
model Plan {
  id        String   @id @default(cuid())
  asaasId   String?  @unique // Asaas plan ID for payment processing
  clerkId   String?  @unique // Legacy Clerk plan ID (deprecated)
  clerkName String?  // Legacy field
  name      String
  credits   Int
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  // Pricing configuration (amounts in cents)
  // Asaas only supports BRL (Brazilian Real)
  currency           String?  @default("brl")
  priceMonthlyCents  Int?
  priceYearlyCents   Int?
  description        String?  @db.Text
  features           Json?
  badge              String?
  highlight          Boolean  @default(false)
  ctaType            String?  @default("contact")
  ctaLabel           String?
  ctaUrl             String?
  billingSource      String   @default("manual")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
  @@index([sortOrder])
}

// File/object uploads tracked for admin management
model StorageObject {
  id           String   @id @default(cuid())
  userId       String
  clerkUserId  String
  provider     String   @default("vercel_blob")
  url          String
  pathname     String
  name         String
  contentType  String?
  size         Int
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([clerkUserId])
  @@index([contentType])
  @@index([deletedAt])
  @@index([name])
}

// Essay - one per type per user (Chevening + Fulbright)
model Essay {
  id        String      @id @default(cuid())
  userId    String
  type      EssayType
  status    EssayStatus @default(DRAFT)
  title     String?
  content   String      @db.Text
  wordCount Int         @default(0)
  latestScore Float?
  analysisCount Int     @default(0)
  scholarship String    @default("chevening")
  fulbrightCategory FulbrightCategory?
  hostInstitution   String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user      User        @relation(fields: [userId], references: [id])
  versions  EssayVersion[]
  analyses  EssayAnalysis[]

  @@unique([userId, type])
  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([scholarship])
}

// Versioned snapshots of essay content
model EssayVersion {
  id        String   @id @default(cuid())
  essayId   String
  version   Int
  content   String   @db.Text
  wordCount Int      @default(0)
  createdAt DateTime @default(now())

  essay     Essay    @relation(fields: [essayId], references: [id], onDelete: Cascade)

  @@index([essayId])
  @@index([essayId, version])
}

// AI analysis results for an essay
model EssayAnalysis {
  id              String   @id @default(cuid())
  essayId         String
  versionNumber   Int
  score           Float
  status          String   @default("completed")
  feedback        Json
  contentSnapshot String   @db.Text
  wordCount       Int      @default(0)
  creditsUsed     Int      @default(10)
  createdAt       DateTime @default(now())

  essay           Essay    @relation(fields: [essayId], references: [id], onDelete: Cascade)

  @@index([essayId])
  @@index([essayId, createdAt])
}

// Track subscription lifecycle events for revenue analytics
model SubscriptionEvent {
  id           String   @id @default(cuid())
  userId       String?
  clerkUserId  String
  planKey      String?
  status       String
  eventType    String
  occurredAt   DateTime @default(now())
  metadata     Json?
  createdAt    DateTime @default(now())

  user         User?    @relation(fields: [userId], references: [id])

  @@index([clerkUserId, occurredAt])
  @@index([userId, occurredAt])
}

// Deck de flashcards para Mock Interview
model FlashcardDeck {
  id           String   @id @default(cuid())
  userId       String
  name         String   @default("Deck")
  totalCards   Int      @default(0)
  studiedCards Int      @default(0)
  creditsUsed  Int      @default(15)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcards Flashcard[]
  sessions   StudySession[]

  @@index([userId])
  @@index([createdAt])
}

// Flashcard individual
model Flashcard {
  id           String    @id @default(cuid())
  deckId       String
  question     String    @db.Text
  answer       String    @db.Text
  category     String    // validation, deepening, situational, consistency
  relatedEssay Int?      // 1-4
  tips         String?   @db.Text
  order        Int       @default(0)
  studied      Boolean   @default(false)
  studiedAt    DateTime?
  createdAt    DateTime  @default(now())

  deck FlashcardDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@index([deckId])
  @@index([deckId, order])
}

// Sessão de estudo
model StudySession {
  id           String   @id @default(cuid())
  deckId       String
  cardsStudied Int      @default(0)
  duration     Int      @default(0) // segundos
  mode         String   @default("sequential") // sequential, random
  createdAt    DateTime @default(now())

  deck FlashcardDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@index([deckId])
  @@index([createdAt])
}

enum AudioResponseStatus {
  PENDING
  RECORDED
  ANALYZING
  ANALYZED
  FAILED
}

model AudioInterviewSession {
  id            String   @id @default(cuid())
  userId        String
  name          String   @default("Sessão")
  totalQuestions Int     @default(5)
  answeredCount Int     @default(0)
  analyzedCount Int     @default(0)
  averageScore  Float?
  creditsUsed   Int     @default(15)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses AudioInterviewResponse[]

  @@index([userId])
  @@index([createdAt])
}

model AudioInterviewResponse {
  id          String              @id @default(cuid())
  sessionId   String
  questionIndex Int
  question    String              @db.Text
  audioUrl    String?
  audioPath   String?
  duration    Int?
  transcript  String?             @db.Text
  status      AudioResponseStatus @default(PENDING)
  score       Float?
  feedback    Json?
  creditsUsed Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  session AudioInterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionIndex])
  @@index([sessionId])
  @@index([status])
}

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CANDIDATE
  RECRUITER
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String?  @unique
  name      String?
  locale    String   @default("en-US")
  role      UserRole?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  creditBalance      CreditBalance?
  usageHistory       UsageHistory[]
  storageObjects     StorageObject[]
  subscriptionEvents SubscriptionEvent[]
  resumes            Resume[]
  coverLetters       CoverLetter[]
  jobApplications    JobApplication[]
  flashcardDecks     FlashcardDeck[]
  workplaceScenarioSessions WorkplaceScenarioSession[]
  company            Company?
  pipelineEntries    CandidatePipelineEntry[]
  stageHistoryMoves  CandidateStageHistory[]
  notifications      InAppNotification[]
  asaasCustomerId    String?   @unique
  asaasCustomerIdSandbox    String?   @unique
  asaasCustomerIdProduction String?   @unique
  asaasSubscriptionId String?
  currentPlanId      String?
  cpfCnpj            String?
  billingPeriodEnd      DateTime?
  cancellationScheduled Boolean  @default(false)
  cancellationDate      DateTime?

  // Profile fields
  province         String?
  birthYear        Int?
  gender           String?
  course           String?
  university       String?
  profileComplete  Boolean  @default(false)

  // Extended career profile fields
  careerPath       String?
  industry         String?
  experienceLevel  ExperienceLevel?
  englishLevel     EnglishLevel?
  targetRole       String?
  currentRole      String?
  skills           String[]

  @@index([email])
  @@index([name])
  @@index([createdAt])
  @@index([isActive])
  @@index([currentPlanId])
  @@index([role])
}

// Company profile for RECRUITER users
model Company {
  id          String   @id @default(cuid())
  userId      String   @unique
  name        String
  description String   @db.Text
  location    String
  website     String?
  email       String
  logoUrl     String?
  logoPath    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postings    JobPosting[]

  @@index([userId])
  @@index([createdAt])
}

enum JobPostingStatus {
  DRAFT
  PUBLISHED
  PAUSED
  CLOSED
}

enum JobPostingCategory {
  TECHNOLOGY
  FINANCE
  HEALTHCARE
  EDUCATION
  ENGINEERING
  MARKETING
  SALES
  HUMAN_RESOURCES
  LEGAL
  OPERATIONS
  LOGISTICS
  HOSPITALITY
  CONSTRUCTION
  MEDIA
  OTHER
}

enum SalaryRange {
  UNDER_15K
  FROM_15K_TO_25K
  FROM_25K_TO_40K
  FROM_40K_TO_60K
  FROM_60K_TO_90K
  ABOVE_90K
  NEGOTIABLE
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  REMOTE
  HYBRID
}

model JobPosting {
  id          String             @id @default(cuid())
  companyId   String
  title       String
  category    JobPostingCategory
  salaryRange SalaryRange
  jobType     JobType
  description String             @db.Text
  status      JobPostingStatus   @default(DRAFT)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  company          Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications     JobApplication[]
  pipelineEntries  CandidatePipelineEntry[]
  interviewStages  RecruitmentInterviewStage[]

  @@index([companyId])
  @@index([status])
  @@index([category])
  @@index([createdAt])
  @@index([companyId, status])
}

enum PipelineStage {
  RECEIVED
  REVIEWING
  INTERVIEW
  OFFER
  REJECTED
  ACCEPTED
}

// CandidatePipelineEntry - links a candidate's application to a recruiter's pipeline
model CandidatePipelineEntry {
  id                        String        @id @default(cuid())
  jobPostingId              String
  userId                    String
  jobApplicationId          String        @unique
  currentStage              PipelineStage @default(RECEIVED)
  currentRecruitmentStageId String?
  fitScore                  Float?
  notes                     String?       @db.Text
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt

  jobPosting               JobPosting               @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  jobApplication           JobApplication           @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)
  user                     User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentRecruitmentStage  RecruitmentInterviewStage? @relation(fields: [currentRecruitmentStageId], references: [id], onDelete: SetNull)
  stageHistory             CandidateStageHistory[]

  @@index([jobPostingId])
  @@index([userId])
  @@index([jobPostingId, currentStage])
  @@index([currentRecruitmentStageId])
  @@index([createdAt])
}

// CandidateStageHistory - audit trail of pipeline stage transitions
model CandidateStageHistory {
  id          String        @id @default(cuid())
  entryId     String
  movedBy     String
  fromStage   PipelineStage
  toStage     PipelineStage
  movedAt     DateTime      @default(now())

  entry       CandidatePipelineEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  mover       User                   @relation(fields: [movedBy], references: [id], onDelete: Cascade)

  @@index([entryId])
  @@index([movedBy])
  @@index([movedAt])
}

enum InterviewStageFocus {
  TECHNICAL
  BEHAVIORAL
  MIXED
}

enum InterviewStageStatus {
  DRAFT
  PUBLISHED
}

// RecruitmentInterviewStage - a named interview stage created by recruiter for a job posting
model RecruitmentInterviewStage {
  id            String               @id @default(cuid())
  jobPostingId  String
  name          String
  questionCount Int                  @default(5)
  focusType     InterviewStageFocus  @default(MIXED)
  status        InterviewStageStatus @default(DRAFT)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  jobPosting      JobPosting                    @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  questions       RecruitmentInterviewQuestion[]
  sessions        WorkplaceScenarioSession[]
  pipelineEntries CandidatePipelineEntry[]

  @@index([jobPostingId])
  @@index([status])
  @@index([createdAt])
}

// RecruitmentInterviewQuestion - individual question within a recruitment stage
model RecruitmentInterviewQuestion {
  id          String   @id @default(cuid())
  stageId     String
  prompt      String   @db.Text
  questionType String
  order       Int      @default(0)
  isEdited    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stage RecruitmentInterviewStage @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@index([stageId])
  @@index([stageId, order])
}

// InAppNotification - in-app notifications for candidates
model InAppNotification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String   @db.Text
  data      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
  @@index([createdAt])
}

enum ExperienceLevel {
  ENTRY
  JUNIOR
  MID
  SENIOR
  LEAD
  EXECUTIVE
}

enum EnglishLevel {
  BEGINNER
  ELEMENTARY
  INTERMEDIATE
  UPPER_INTERMEDIATE
  ADVANCED
  PROFICIENT
}

enum AgentSkill {
  JOB_HUNTER
  APPLICATION_OPTIMIZER
  MARKET_FIT
  BUSINESS_ENGLISH
  RESUME_BUILDER
}

// Workspace features and linkage to projects
model Feature {
  id          String     @id @default(cuid())
  workspaceId String
  name        String
  description String?
  tags        String[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
}

model CreditBalance {
  id                String   @id @default(cuid())
  userId            String   @unique
  clerkUserId       String   @unique
  creditsRemaining  Int      @default(100)
  lastSyncedAt      DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id])
  usageHistory      UsageHistory[]

  @@index([userId])
  @@index([clerkUserId])
  @@index([creditsRemaining])
  @@index([lastSyncedAt])
}

model UsageHistory {
  id              String   @id @default(cuid())
  userId          String
  creditBalanceId String
  operationType   OperationType
  creditsUsed     Int
  details         Json?
  timestamp       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id])
  creditBalance   CreditBalance @relation(fields: [creditBalanceId], references: [id])

  @@index([userId])
  @@index([creditBalanceId])
  @@index([timestamp])
  @@index([operationType])
  @@index([userId, timestamp])
  @@index([operationType, timestamp])
}

enum OperationType {
  AI_TEXT_CHAT
  AI_IMAGE_GENERATION
  CV_ANALYSIS
  JOB_MATCH
  INTERVIEW_PREP
  SCENARIO_SIMULATION
  BUSINESS_ENGLISH_SESSION
}

// Singleton row storing admin-configurable credit settings
model AdminSettings {
  id           String   @id @default("singleton")
  featureCosts Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Subscription plans managed manually and optionally linked to payment providers
model Plan {
  id        String   @id @default(cuid())
  asaasId   String?  @unique
  clerkId   String?  @unique
  clerkName String?
  name      String
  credits   Int
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  currency           String?  @default("brl")
  priceMonthlyCents  Int?
  priceYearlyCents   Int?
  description        String?  @db.Text
  features           Json?
  badge              String?
  highlight          Boolean  @default(false)
  ctaType            String?  @default("contact")
  ctaLabel           String?
  ctaUrl             String?
  billingSource      String   @default("manual")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
  @@index([sortOrder])
}

// File/object uploads tracked for admin management
model StorageObject {
  id           String   @id @default(cuid())
  userId       String
  clerkUserId  String
  provider     String   @default("vercel_blob")
  url          String
  pathname     String
  name         String
  contentType  String?
  size         Int
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([clerkUserId])
  @@index([contentType])
  @@index([deletedAt])
  @@index([name])
}

// Resume - stores uploaded CV content/file reference and parsed data
model Resume {
  id            String   @id @default(cuid())
  userId        String
  title         String?
  content       String?  @db.Text
  fileUrl       String?
  filePath      String?
  parsedData    Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobApplications JobApplication[]

  @@index([userId])
  @@index([createdAt])
}

// CoverLetter - optional uploaded cover letter
model CoverLetter {
  id            String   @id @default(cuid())
  userId        String
  title         String?
  content       String?  @db.Text
  fileUrl       String?
  filePath      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobApplications JobApplication[]

  @@index([userId])
  @@index([createdAt])
}

// JobApplication - stores job description text, company info, and links to resume
model JobApplication {
  id                  String   @id @default(cuid())
  userId              String
  resumeId            String?
  coverLetterId       String?
  jobTitle            String?
  companyName         String?
  jobDescription      String   @db.Text
  companyInfo         String?  @db.Text
  status              JobApplicationStatus @default(DRAFT)
  jobPostingId        String?
  isPublicApplication Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume           Resume?    @relation(fields: [resumeId], references: [id])
  coverLetter      CoverLetter? @relation(fields: [coverLetterId], references: [id])
  jobPosting       JobPosting? @relation(fields: [jobPostingId], references: [id], onDelete: SetNull)
  analyses         ApplicationAnalysis[]
  analysisExecutions ApplicationAnalysisExecution[]
  scenarioSessions WorkplaceScenarioSession[]
  pipelineEntry    CandidatePipelineEntry?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([jobPostingId])
}

enum JobApplicationStatus {
  DRAFT
  ANALYZING
  ANALYZED
  APPLIED
  INTERVIEWING
  OFFERED
  REJECTED
  ACCEPTED
}

enum ApplicationAnalysisExecutionStatus {
  PENDING
  COMPLETED
  FAILED
}

// ApplicationAnalysis - AI comparison results (resume vs job description)
model ApplicationAnalysis {
  id                String   @id @default(cuid())
  jobApplicationId  String
  fitScore          Float?
  summary           String?  @db.Text
  skillsMatch       Json?
  missingSkills     Json?
  strengths         Json?
  improvements      Json?
  recommendations   Json?
  keywordAnalysis   Json?
  rawResponse       String?  @db.Text
  agentSkill        AgentSkill?
  creditsUsed       Int      @default(10)
  createdAt         DateTime @default(now())

  jobApplication    JobApplication @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)

  @@index([jobApplicationId])
  @@index([jobApplicationId, createdAt])
}

model ApplicationAnalysisExecution {
  id                    String   @id @default(cuid())
  jobApplicationId      String
  userId                String
  inputHash             String
  idempotencyKey        String?
  status                ApplicationAnalysisExecutionStatus @default(PENDING)
  applicationAnalysisId String?  @unique
  creditsCharged        Boolean  @default(false)
  creditsRefunded       Boolean  @default(false)
  lastError             String?  @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  jobApplication        JobApplication @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)

  @@unique([jobApplicationId, inputHash])
  @@unique([jobApplicationId, idempotencyKey])
  @@index([userId])
  @@index([status])
  @@index([jobApplicationId, status])
}

// Track subscription lifecycle events for revenue analytics
model SubscriptionEvent {
  id           String   @id @default(cuid())
  userId       String?
  clerkUserId  String
  planKey      String?
  status       String
  eventType    String
  occurredAt   DateTime @default(now())
  metadata     Json?
  createdAt    DateTime @default(now())

  user         User?    @relation(fields: [userId], references: [id])

  @@index([clerkUserId, occurredAt])
  @@index([userId, occurredAt])
}

// FlashcardDeck for job interview preparation
model FlashcardDeck {
  id           String   @id @default(cuid())
  userId       String
  name         String   @default("Interview Prep Deck")
  category     InterviewCategory?
  totalCards   Int      @default(0)
  studiedCards Int      @default(0)
  creditsUsed  Int      @default(15)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcards Flashcard[]
  sessions   StudySession[]

  @@index([userId])
  @@index([createdAt])
}

enum InterviewCategory {
  BEHAVIORAL
  TECHNICAL
  SITUATIONAL
  CULTURE_FIT
  BUSINESS_ENGLISH
}

// Flashcard for interview Q&A
model Flashcard {
  id           String    @id @default(cuid())
  deckId       String
  question     String    @db.Text
  answer       String    @db.Text
  category     String
  relatedSkill String?
  tips         String?   @db.Text
  order        Int       @default(0)
  studied      Boolean   @default(false)
  studiedAt    DateTime?
  createdAt    DateTime  @default(now())

  deck FlashcardDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@index([deckId])
  @@index([deckId, order])
}

// Study session
model StudySession {
  id           String   @id @default(cuid())
  deckId       String
  cardsStudied Int      @default(0)
  duration     Int      @default(0)
  mode         String   @default("sequential")
  createdAt    DateTime @default(now())

  deck FlashcardDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@index([deckId])
  @@index([createdAt])
}

enum ScenarioResponseStatus {
  PENDING
  RECORDED
  ANALYZING
  ANALYZED
  FAILED
}

// WorkplaceScenarioSession - simulates real interview scenarios for a specific job application
model WorkplaceScenarioSession {
  id                   String   @id @default(cuid())
  userId               String
  jobApplicationId     String?
  recruitmentStageId   String?
  name                 String   @default("Interview Practice")
  scenarioType         ScenarioType?
  totalQuestions       Int      @default(5)
  answeredCount        Int      @default(0)
  analyzedCount        Int      @default(0)
  averageScore         Float?
  creditsUsed          Int      @default(15)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user              User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobApplication    JobApplication?             @relation(fields: [jobApplicationId], references: [id], onDelete: SetNull)
  recruitmentStage  RecruitmentInterviewStage?  @relation(fields: [recruitmentStageId], references: [id], onDelete: SetNull)
  responses         WorkplaceScenarioResponse[]

  @@unique([userId, recruitmentStageId])
  @@index([userId])
  @@index([jobApplicationId])
  @@index([recruitmentStageId])
  @@index([createdAt])
}

enum ScenarioType {
  TEAM_MEETING
  CLIENT_CALL
  PRESENTATION
  EMAIL_DICTATION
  CONFLICT_RESOLUTION
  PERFORMANCE_REVIEW
  NEGOTIATION
}

// WorkplaceScenarioResponse - individual responses within a scenario session
model WorkplaceScenarioResponse {
  id          String                @id @default(cuid())
  sessionId   String
  questionIndex Int
  prompt      String                @db.Text
  audioUrl    String?
  audioPath   String?
  duration    Int?
  transcript  String?               @db.Text
  status      ScenarioResponseStatus @default(PENDING)
  score       Float?
  feedback    Json?
  creditsUsed Int                   @default(0)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  session WorkplaceScenarioSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionIndex])
  @@index([sessionId])
  @@index([status])
}

{
  "name": "standout",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "prisma generate && next dev -H 0.0.0.0 -p 5000",
    "dev:tunnel": "vercel dev --tunnel",
    "dev:e2e": "node scripts/dev-e2e.mjs",
    "tunnel": "ngrok http 3000",
    "tunnel:ngrok": "ngrok http 3000",
    "tunnel:cf": "cloudflare tunnel --url http://localhost:3000",
    "env:pull": "vercel env pull .env.local",
    "build": "prisma generate && next build",
    "start": "next start -H 0.0.0.0 -p 5000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:unit": "vitest",
    "test:unit:watch": "vitest --watch",
    "test:unit:coverage": "vitest --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:docker": "node scripts/setup-postgres-docker.mjs",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio"
  },
  "dependencies": {

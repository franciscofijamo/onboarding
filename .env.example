# ============================
# Core Application Settings
# ============================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================
# Database (Prisma + Postgres)
# ============================
DATABASE_URL="postgresql://user:password@localhost:5432/saas_template"

# ============================
# Clerk Authentication
# ============================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_cHJlY2lzZS1sYWNld2luZy0zOS5jbGVyay5hY2NvdW50cy5kZXYk
CLERK_SECRET_KEY=sk_test_Rcya3zPc4MfWQWxx8XCpqqMyWYfbsBh5RHhaf3n1HF
CLERK_WEBHOOK_SECRET=
# Optional: use if your Clerk Billing API key is different from CLERK_SECRET_KEY
CLERK_BILLING_APIKEY=
# Optional legacy fallback for webhooks (if CLERK_WEBHOOK_SECRET isn't set)
WEBHOOK_SECRET=

# Clerk routes (template defaults)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ============================
# Admin Access (set at least one)
# ============================
ADMIN_EMAILS=valuu.apps@gmail.com,franciscocaetanodata@gmail.com

ADMIN_USER_IDS=

# ============================
# AI (OpenRouter)
# ============================
OPENROUTER_API_KEY=

# ============================
# Storage (Uploads)
# ============================
# STORAGE_PROVIDER can be: vercel_blob | replit
STORAGE_PROVIDER=
# Vercel Blob
BLOB_READ_WRITE_TOKEN=
# Replit App Storage
REPLIT_STORAGE_BUCKET_ID=
# Optional: override public base URL for Replit storage
REPLIT_STORAGE_PUBLIC_BASE_URL=
# Upload size limit (MB)
BLOB_MAX_SIZE_MB=25

# ============================
# Asaas Payments
# ============================
ASAAS_API_KEY=
# Optional: defaults to sandbox if not set
# ASAAS_API_URL=https://sandbox.asaas.com/api/v3
# Production example:
# ASAAS_API_URL=https://api.asaas.com/v3
ASAAS_API_URL=
ASAAS_WEBHOOK_SECRET=



# ============================
# M-Pesa (Mozambique) Payments
# ============================
MPESA_API_KEY=yrfar0kpcz86evpvonaxx2nykvrlruqx
MPESA_PUBLIC_

# Example sandbox base URL:
# MPESA_BASE_URL=https://api.sandbox.vm.co.mz:18352
MPESA_BASE_URL=https://api.vm.co.mz:18352
MPESA_C2B_PATH=/ipg/v1x/c2bPayment/singleStage/
MPESA_ORIGIN=developer.mpesa.vm.co.mz
MPESA_SERVICE_PROVIDER_CODE=901819
# Timeout for STK Push (ms) - should cover customer PIN entry window
MPESA_TIMEOUT_MS=65000

# ============================
# Payment Provider
# ============================
# auto | mpesa | asaas
PAYMENT_PROVIDER=auto


# ============================
# Webhooks
# ============================
# Used by /api/webhooks/users
USER_WEBHOOK_SECRET=

# ============================
# Analytics (optional)
# ============================
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=

# ============================
# Logging & Debugging (optional)
# ============================
API_LOGGING=false
NEXT_PUBLIC_API_LOGGING=false
# debug | info | warn | error
API_LOG_LEVEL=warn
# Log only responses with status >= this value
API_LOG_MIN_STATUS=400
DEBUG_CLERK_SYNC=0
IMAGE_DEBUG=0

# ============================
# E2E / Dev Helpers (optional)
# ============================
E2E_AUTH_BYPASS=0
NEXT_PUBLIC_E2E_TEST=0

# ============================
# Postgres Docker Script (optional)
# ============================
PG_CONTAINER_NAME=saas_template
PG_DB=saas_template
PG_USER=postgres
PG_PASSWORD=postgres
PG_PORT=5432
PG_IMAGE=postgres:16
PG_VOLUME=saas_template_data
